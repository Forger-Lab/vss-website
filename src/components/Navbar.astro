<style>
  .nav-container {
    display: flex;
    flex-direction: column;
  }

  .nav-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 64px;
    position: relative; /* needed for ::before pseudo-element */
    /* Figma gradient */
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    overflow: hidden;
  }

  /* Frosted-glass layer sits on top of the gradient */
  .nav-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.08); /* subtle white sheen */
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none; /* clicks pass through */
    z-index: 0;
    display: none;
  }

  /* Lift all direct children above the glass layer */
  .nav-banner > * {
    position: relative;
    z-index: 1;
  }

  .search-btn {
    width: 32px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-secondary);
    border-radius: 10px;
  }

  .rounded-bdr {
    border-style: solid;
