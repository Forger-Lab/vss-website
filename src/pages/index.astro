---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "@/components/HeroSection.astro";
import LogoCarousel from "@/components/LogoCarousel.astro";
import TrustedSection from "@/components/TrustedSection.astro";
import ServicesSection from "@/components/ServicesSection.astro";
import ChooseSection from "@/components/ChooseSection.astro";
import TestimonialSection from "@/components/TestimonialSection.astro";
import CertificationsSection from "@/components/CertificationsSection.astro";
import FinalCtaSection from "@/components/FinalCtaSection.astro";

const accreditations = [
  { src: "/slider/14001-RGB-White.jpg", alt: "ISO 14001" },
  { src: "/slider/27001-CMYK-White.jpg", alt: "ISO 27001" },
  { src: "/slider/45001-CMYK-White.jpg", alt: "ISO 45001" },
  { src: "/slider/Achilles.jpg", alt: "Achilles" },
  { src: "/slider/Constructionline.jpg", alt: "Constructionline" },
  { src: "/slider/Investor-In-People.jpg", alt: "Investor in People" },
  { src: "/slider/Iso-9002-logo.png", alt: "ISO 9001" },
  { src: "/slider/NSI-GOLD-UKAS-PCMS-RGB-300dpi.jpg", alt: "NSI Gold" },
  { src: "/slider/PSA.jpg", alt: "PSA" },
  { src: "/slider/safecontractor-round-RGB-297x300-1(1).jpg", alt: "SafeContractor" },
  { src: "/slider/SIA-logo-grey.jpg", alt: "SIA" },
];
---

<BaseLayout
  title="Home"
  description="Vigilant Security Services — proactive, technology-driven security solutions for businesses and communities across the UK."
>
  <HeroSection />
  <LogoCarousel images={accreditations} />
  <TrustedSection />
  <ServicesSection />
  <ChooseSection />
  <TestimonialSection />
  <CertificationsSection images={accreditations} />
  <FinalCtaSection />
</BaseLayout>
